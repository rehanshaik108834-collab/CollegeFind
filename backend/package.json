{
  "name": "college-discovery-backend",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
